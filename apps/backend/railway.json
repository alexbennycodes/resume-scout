{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildArgs": {
      "PYTHON_VERSION": "3.11"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port $PORT",
    "healthcheck": {
      "path": "/api/v1/health",
      "port": 8000,
      "initialDelaySeconds": 30,
      "timeoutSeconds": 10,
      "periodSeconds": 10
    }
  }
}